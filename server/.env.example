# 数据库配置
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=shimmer

# JWT 密钥（生产环境请使用复杂的随机字符串）
JWT_SECRET=your_jwt_secret_change_this

# 服务器端口
PORT=3000

# 前端配置
FRONTEND_URL=http://localhost:5173

# 上传目录
UPLOAD_DIR=uploads

# AI 配置（可选）
AI_PROVIDER=ollama
AI_MODEL=llama2
AI_BASE_URL=http://127.0.0.1:11434
AI_API_KEY=
AI_TIMEOUT=10000
